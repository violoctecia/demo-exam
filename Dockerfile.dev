# ── Dev image: зависимости запекаются в слой образа ───────────────────────────
FROM node:22-alpine

RUN npm install -g pnpm

WORKDIR /app

# Копируем только манифесты — этот слой кэшируется Docker'ом,
# поэтому pnpm install не нужен интернет при пересборке без изменений пакетов
COPY package.json pnpm-lock.yaml ./
RUN pnpm install

# Исходники будут примонтированы через volume при запуске контейнера.
# node_modules из образа перекроет примонтированную папку (anonymous volume).

CMD ["sh", "-c", "npx prisma generate && npx prisma migrate deploy && npx prisma db seed && pnpm dev"]
